<main>
    <div>
        {{#with page_header}}
        <h1>{{title}}</h1>
        <p>{{description}}</p>
        {{/with}}
    </div>

    <section>
        {{#with section}}
        <div class="card">
            <div class="card-body">
                {{#with about_us}}

                {{#with title_list}}
                <div class="display-6 text-end">{{main}}</div>
                <h2 class="text-end">{{sub}}</h2>
                {{/with}}
                {{#with button}}
                <a class="btn btn-outline-info btn-sm">{{text}}</a>
                {{/with}}

                {{/with}}
            </div>
        </div>
        <br>
        <div class="card">
            <div class="card-body">
                {{#with advantage}}
                <div class="display-5">{{title}}</div>
                <div class="card">
                    <div class="card-body">
                        {{#with efficiency}}
                        <div class="display-4">{{title}}</div>
                        <h6>{{sub_title}}</h6>
                        <p>{{description}}</p>
                        <a class="btn btn-outline-warning">{{button}}</a>
                        {{/with}}
                    </div>
                </div>
                <br>
                <div class="card">
                    <div class="card-body">
                        {{#with innovation}}
                        <div class="display-4 text-center">{{title}}</div>
                        <h6 class="text-center">{{sub_title}}</h6>
                        <p class="text-center">{{description}}</p>
                        <a class="btn btn-outline-warning">{{button}}</a>
                        {{/with}}
                    </div>
                </div>
                <br>

                <div class="card">
                    <div class="card-body">
                        {{#with collaboration}}
                        <div class="display-4 text-end">{{title}}</div>
                        <h6 class="text-end">{{sub_title}}</h6>
                        <p class="text-end">{{description}}</p>
                        <a class="btn btn-outline-warning">{{button}}</a>
                        {{/with}}
                    </div>
                </div>
                {{/with}}
            </div>
        </div>
        <br>

        <div class="card">
            <div class="card-body">
                {{#with agreement}}
                <div class="display-5">{{title}}</div>
                <div class="card">
                    <div class="card-body">
                        {{#with info}}
                        <h5>{{sub_title}}</h5>
                        <div class="card">
                            <div class="card-body">
                                {{#with detail}}
                                <p>{{text}}</p>
                                <a class="btn btn-success">{{button}}</a>
                                {{/with}}
                            </div>
                        </div>
                        {{/with}}
                    </div>
                </div>


                {{/with}}

            </div>
        </div>


        {{/with}}

    </section>


</main>